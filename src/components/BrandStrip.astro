<section class="brand-strip">
  <div class="container">
    <p class="brand-strip__label">Our brands</p>
    <div class="brand-strip__logos">
      <a href="/brands#99-fm">99 FM</a>
      <a href="/brands#omulunga">Radio Omulunga</a>
      <a href="/brands#one-africa">One Africa</a>
      <a href="/brands#on-one">On One Sports</a>
      <a href="/brands#entryfy">Entryfy</a>
      <a href="/brands#specials">Specials.na</a>
      <a href="/brands#promobasket">Promobasket</a>
      <a href="/brands#property-news">Property News</a>
      <a href="/shop-beat">Shop Beat</a>
    </div>
  </div>
</section>

<style>
  .brand-strip {
    background: #313E4A;
    padding: 36px 0;
  }

  .brand-strip__label {
    text-align: center;
    color: rgba(255,255,255,0.5);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 20px;
  }

  .brand-strip__logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 28px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .brand-strip__logos a {
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    font-weight: 600;
    transition: color 0.2s;
  }

  .brand-strip__logos a:hover {
    color: #E3564E;
  }

  @media (max-width: 768px) {
    .brand-strip {
      padding: 28px 16px;
    }

    .brand-strip__logos {
      gap: 10px 16px;
    }

    .brand-strip__logos a {
      font-size: 13px;
    }
  }
</style>
