---
import { events } from '../data/events';
---

<section class="section section--light">
  <div class="container">
    <h2 class="section__title">Latest Events</h2>
    <div class="card-grid">
      {events.map((event) => (
        <article class="card">
          <div class="card__image">
            <img src={event.image} alt={event.title} />
          </div>
          <div class="card__body">
            <span class="card__date">{event.date}</span>
            <h3 class="card__title">{event.title}</h3>
            <p class="card__excerpt">{event.excerpt}</p>
            <a href={`/events/${event.slug}`} class="card__link">Read more</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
