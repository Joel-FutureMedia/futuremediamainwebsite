---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Vision & Mission" description="Future Media vision and mission — Namibia's most connected media partner.">
  <div class="page-hero">
    <div class="container">
      <h1>Vision &amp; Mission</h1>
      <p>Professional, direct, Namibia-first and data-led.</p>
    </div>
  </div>
  <div class="page-content">
    <div class="container page-content__inner">
      <h2>Our Vision</h2>
      <p>To be Namibia's most connected media partner — the first choice for brands and agencies who need reach, insight and results across radio, TV, digital, retail media, activations and technology.</p>

      <h2>Our Mission</h2>
      <p>We convert attention into qualified opportunities. We help local businesses and media buying agencies plan smarter campaigns with audience intelligence, integrated inventory and clear lead paths — from free media audits to gated research downloads.</p>

      <div class="feature-grid">
        <div class="feature-card">
          <h3>Namibia-first</h3>
          <p>Local audiences, languages and market context at the centre of every recommendation.</p>
        </div>
        <div class="feature-card">
          <h3>Data-led</h3>
          <p>Universe stats, brand teasers and quarterly audience updates for buyers who need proof.</p>
        </div>
        <div class="feature-card">
          <h3>Lead with purpose</h3>
          <p>No anonymous downloads — every document and enquiry captures a contact detail.</p>
        </div>
      </div>

      <h2>Company values</h2>
      <ul>
        <li>Audience first — listen, engage, deliver content that resonates</li>
        <li>Innovation — evolve platforms as consumption habits change</li>
        <li>Partnership — treat every campaign as a shared success</li>
        <li>Integrity — transparent rates, reporting and POPIA-aware consent</li>
      </ul>

      <p style="margin-top: 24px;"><a href="/about/company-profile" class="btn-primary">Download our company profile</a></p>
    </div>
  </div>
</BaseLayout>
