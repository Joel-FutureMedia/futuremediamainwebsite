---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Audiences & Insights" description="Future Media universe reach, brand audience teasers and gated full data downloads.">
  <div class="page-hero">
    <div class="container">
      <h1>Audiences &amp; Insights</h1>
      <p>Data-driven intelligence for media buyers — headline stats public, full decks gated.</p>
    </div>
  </div>
  <div class="page-content">
    <div class="container page-content__inner">
      <h2>Future Media Universe</h2>
      <div class="feature-grid">
        <div class="feature-card"><h3>2.5M+</h3><p>Weekly radio listeners across the group</p></div>
        <div class="feature-card"><h3>1.2M+</h3><p>Monthly digital page views</p></div>
        <div class="feature-card"><h3>4.5M+</h3><p>Weekly outdoor impressions</p></div>
      </div>
      <p><a href="/about/company-profile" class="btn-primary">Download full Universe overview</a></p>
      <p style="font-size: 13px; color: #5a6570; margin-top: 8px;">Email capture required — PDF mailed to you. Audience data updated quarterly.</p>

      <h2>Brand audience cards</h2>
      <p>One-line descriptors and teaser stats per radio/TV brand. Full audience &amp; engagement slides are gated.</p>
      <ul>
        <li><strong>99 FM</strong> — Urban youth &amp; working adults · strong drive-time engagement</li>
        <li><strong>Radio Omulunga</strong> — Northern Namibia · Oshiwambo-speaking communities</li>
        <li><strong>One Africa</strong> — Contemporary African entertainment audiences</li>
        <li><strong>On One Sports</strong> — Sports fans · cricket, rugby, football</li>
      </ul>
      <p><a href="/about/company-profile" class="btn-primary">Download full audience data</a></p>

      <h2>Digital &amp; tech platforms</h2>
      <div class="feature-grid">
        <div class="feature-card"><h3>Specials.na</h3><p>Deals audience — find out more via contact form.</p></div>
        <div class="feature-card"><h3>Shop Beat</h3><p>In-store retail media — request a Namibia demo.</p></div>
        <div class="feature-card"><h3>Entryfy</h3><p>B2B tech platform — visit Entryfy for product detail.</p></div>
        <div class="feature-card"><h3>Promobasket</h3><p>Promotional media — detailed breakdowns on request.</p></div>
      </div>

      <p style="margin-top: 24px; padding: 16px; background: #f4f5f6; border-radius: 8px; font-size: 14px; color: #5a6570;">
        <strong>Campaign Results</strong> section is built into this page structure but hidden until the first case study is ready.
      </p>
    </div>
  </div>
</BaseLayout>
